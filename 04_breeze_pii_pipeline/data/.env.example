# Azure OpenAI (KGI STT Phase 3 PII evaluation)
# Same Azure resource as chunking_embedding project. Copy to `.env` and fill in.
# Don't commit `.env`.

AZURE_API_KEY=your-azure-api-key
AZURE_ENDPOINT=https://webai-sandbox-resource.cognitiveservices.azure.com/
AZURE_API_VERSION=2024-12-01-preview

# Chat deployment for GPT-4o-mini PII detection.
# Replace with your actual deployment name in Azure (e.g. gpt-4o-mini, gpt-4o-mini-2024-07-18).
AZURE_CHAT_DEPLOYMENT=gpt-4o-mini
